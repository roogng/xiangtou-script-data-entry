mysql:
  host: 127.0.0.1
  port: 3306
  user: root
  password: ""
  database: vill
llm:
  api_key: "..."                 # Tencent LKEAP key
  model: "glm-5.1"
  url: "https://api.lkeap.cloud.tencent.com/plan/v3/chat/completions"
  rpm: 60
  max_retries: 3
  timeout: 120
  web_search: true              # GLM built-in web search (platform-side)
  json_mode: true               # response_format json_object -> valid JSON (escapes quotes)
qiniu:
  access_key: "..."
  secret_key: "..."
  bucket: "..."
  domain: "https://example.com"
  image_path_template: "public/common/{uuid}.jpg"
  max_size_bytes: 1048576
run:
  concurrency: 1
  village_ids_file: village_ids.txt
  overwrite: true
  goods_category_fallback: 0   # category_id used when Kimi's sub-category name doesn't match t_category; 0 = skip that goods record
  premium:
    enabled: false              # off by default; on -> ask LLM for popular villages in `city`, match to vill_village ids
    city: "苏州市"               # which city to pick popular villages from (e.g. 苏州市)
    limit: 20
image_search:
  pixabay_key: ""   # free key from https://pixabay.com/accounts/register/ ; fallback image source (Pixabay License, no attribution)
